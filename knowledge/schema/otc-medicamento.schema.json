{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idb.org.pe/knowledge/schema/otc-medicamento.schema.json",
  "title": "IDB OTC Certified Medicine",
  "description": "Esquema oficial para la capa certificada de medicamentos OTC de IDB MEDIC. Define informacion orientativa, no prescriptiva, con trazabilidad a fuentes oficiales.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "nombre_comercial",
    "principio_activo",
    "categoria_otc",
    "presentaciones",
    "uso_orientativo",
    "no_usar_si",
    "precauciones",
    "dosis_general_orientativa",
    "senales_alarma",
    "interacciones_relevantes",
    "embarazo_lactancia",
    "adulto_mayor",
    "pediatria",
    "fuente_oficial",
    "fecha_revision",
    "estado_validacion"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^otc-medicamento-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "nombre_comercial": {
      "description": "Nombre comercial visible en el mercado cuando la fuente oficial lo respalda. Puede ser generico si el registro no representa una marca.",
      "type": "string",
      "minLength": 1
    },
    "principio_activo": {
      "description": "Principio activo o combinacion de principios activos declarados por la fuente oficial.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "categoria_otc": {
      "description": "Categoria funcional OTC usada para busqueda, filtros y ruteo editorial.",
      "type": "string",
      "enum": [
        "analgesico-antipiretico",
        "antiinflamatorio",
        "antialergico",
        "digestivo",
        "respiratorio",
        "dermatologico",
        "oftalmico",
        "otico",
        "rehidratacion",
        "vitamina-suplemento",
        "salud-bucal",
        "primeros-auxilios",
        "otro"
      ]
    },
    "clasificacion_clinica": {
      "description": "Identidad farmacologica y funcional especifica del medicamento.",
      "type": "string",
      "minLength": 1
    },
    "presentaciones": {
      "description": "Formas farmaceuticas y concentraciones autorizadas o descritas por la fuente oficial. No debe usarse para recomendar una presentacion especifica.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/presentacion"
      }
    },
    "uso_orientativo": {
      "description": "Explicacion general del uso comun del producto. No debe indicar que una persona concreta debe usarlo.",
      "$ref": "#/$defs/textoClinico"
    },
    "no_usar_si": {
      "description": "Contraindicaciones o situaciones donde el usuario debe evitar el producto y consultar.",
      "$ref": "#/$defs/listaClinica"
    },
    "precauciones": {
      "description": "Precauciones clinicas, de conservacion, uso duplicado o grupos con mayor riesgo.",
      "$ref": "#/$defs/listaClinica"
    },
    "dosis_general_orientativa": {
      "description": "Campo reservado para orientacion general basada en rotulado oficial. Debe evitar dosis personalizadas, calculos por paciente o duraciones individualizadas.",
      "type": "object",
      "additionalProperties": false,
      "required": ["texto", "requiere_revision_profesional"],
      "properties": {
        "texto": {
          "$ref": "#/$defs/textoClinico"
        },
        "requiere_revision_profesional": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "senales_alarma": {
      "description": "Situaciones que requieren atencion medica pronta o urgente.",
      "$ref": "#/$defs/listaClinica"
    },
    "interacciones_relevantes": {
      "description": "Interacciones relevantes por medicamentos, alcohol, suplementos, condiciones clinicas o duplicidad de principios activos.",
      "$ref": "#/$defs/listaClinica"
    },
    "efectos_adversos": {
      "description": "Efectos adversos frecuentes o relevantes, diferenciados de las senales de alarma.",
      "$ref": "#/$defs/listaClinica"
    },
    "cuando_consultar": {
      "description": "Umbral de consulta profesional especifico para el medicamento.",
      "$ref": "#/$defs/textoClinico"
    },
    "preguntas_frecuentes": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/preguntaFrecuente" }
    },
    "relaciones_clinicas": {
      "description": "Relaciones verificadas con fichas publicadas de la biblioteca clinica.",
      "type": "array",
      "items": { "$ref": "#/$defs/relacionClinica" }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["titulo", "descripcion", "aliases", "keywords"],
      "properties": {
        "titulo": { "type": "string", "minLength": 1 },
        "descripcion": { "type": "string", "minLength": 1 },
        "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "embarazo_lactancia": {
      "$ref": "#/$defs/grupoRiesgo"
    },
    "adulto_mayor": {
      "$ref": "#/$defs/grupoRiesgo"
    },
    "pediatria": {
      "$ref": "#/$defs/grupoRiesgo"
    },
    "fuente_oficial": {
      "description": "Fuentes regulatorias, institucionales o cientificas usadas para validar el registro.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fuenteOficial"
      }
    },
    "fecha_revision": {
      "description": "Fecha de revision editorial y clinica del registro.",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "estado_validacion": {
      "description": "Estado operativo dentro del flujo editorial OTC certificado.",
      "type": "string",
      "enum": [
        "borrador",
        "revision-clinica",
        "validado",
        "retirado"
      ]
    },
    "compatibilidad": {
      "description": "Metadatos opcionales para integracion futura sin modificar las fichas actuales.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "knowledge_slug_relacionado": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "search_keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "rco_triage_maximo": {
          "type": "string",
          "enum": ["green", "yellow", "orange", "red"]
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    }
  },
  "$defs": {
    "textoClinico": {
      "type": "string",
      "minLength": 1
    },
    "listaClinica": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "presentacion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forma", "descripcion"],
      "properties": {
        "forma": {
          "type": "string",
          "enum": [
            "tableta",
            "capsula",
            "jarabe",
            "suspension",
            "gotas",
            "solucion",
            "crema",
            "gel",
            "unguento",
            "spray",
            "polvo",
            "sobre",
            "parche",
            "otro"
          ]
        },
        "descripcion": {
          "type": "string",
          "minLength": 1
        },
        "concentracion": {
          "type": "string"
        },
        "via": {
          "type": "string"
        }
      }
    },
    "grupoRiesgo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resumen", "consultar_antes_de_usar"],
      "properties": {
        "resumen": {
          "$ref": "#/$defs/textoClinico"
        },
        "consultar_antes_de_usar": {
          "type": "boolean",
          "const": true
        },
        "notas": {
          "$ref": "#/$defs/listaClinica"
        }
      }
    },
    "fuenteOficial": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organizacion",
        "titulo",
        "url",
        "tipo",
        "fecha_consulta"
      ],
      "properties": {
        "organizacion": {
          "type": "string",
          "minLength": 1
        },
        "titulo": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "tipo": {
          "type": "string",
          "enum": [
            "registro-sanitario",
            "rotulado-oficial",
            "monografia-oficial",
            "guia-institucional",
            "referencia-regulatoria",
            "referencia-educativa"
          ]
        },
        "pais_o_region": {
          "type": "string"
        },
        "fecha_publicacion": {
          "type": "string",
          "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$"
        },
        "fecha_consulta": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "preguntaFrecuente": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pregunta", "respuesta"],
      "properties": {
        "pregunta": { "type": "string", "minLength": 1 },
        "respuesta": { "type": "string", "minLength": 1 }
      }
    },
    "relacionClinica": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tipo", "slug", "titulo"],
      "properties": {
        "tipo": { "type": "string", "enum": ["sintoma", "enfermedad", "examen", "procedimiento", "medicamento"] },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "titulo": { "type": "string", "minLength": 1 }
      }
    }
  }
}
